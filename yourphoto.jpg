<!DOCTYPE html>
<html>
<head>
  <title></title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      background: black;
    }

    img {
      width: 100vw;
      height: 100vh;
      object-fit: cover; /* fills entire screen */
    }
  </style>
</head>
<body>
  <img src="yourphoto.jpg">
</body>
</html>
